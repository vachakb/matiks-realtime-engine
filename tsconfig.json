{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"],
    "types": ["node"]
  },
  // The native shim (src/native, src/index.native.ts) imports react-native-nitro-modules,
  // which only resolves inside a React Native app — it is typechecked there, not in this
  // zero-dependency core. Everything else (core, data, sim, web, tests) is checked here.
  "include": ["src", "test"],
  "exclude": ["src/native", "src/index.native.ts"]
}
